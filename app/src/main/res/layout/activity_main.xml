<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SpeedTest"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvNetworkType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wi-Fi"
                android:textColor="@color/accent_blue"
                android:textSize="14sp"
                android:background="@drawable/chip_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                tools:text="📶 Wi-Fi" />
        </LinearLayout>

        <!-- Phase indicators -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/indicatorPing"
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:background="@drawable/indicator_inactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PING"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/indicatorDownload"
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:background="@drawable/indicator_inactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DOWNLOAD"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/indicatorUpload"
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:background="@drawable/indicator_inactive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPLOAD"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Speedometer -->
        <com.speedtest.app.SpeedometerView
            android:id="@+id/speedometer"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp" />

        <!-- Current speed label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvCurrentSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="@color/text_primary"
                android:textSize="52sp"
                android:fontFamily="@font/inter_bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap START to begin"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="4dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="8dp"
            android:progress="0"
            android:max="100"
            android:progressTint="@color/accent_blue"
            android:progressBackgroundTint="@color/surface"
            android:indeterminateTint="@color/accent_blue" />

        <!-- START Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="160dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="12dp"
            android:text="START"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_start_bg"
            android:elevation="8dp"
            android:stateListAnimator="@null" />

        <!-- Stats cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <!-- Ping card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PING"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tvPing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_cyan"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_bold"
                    tools:text="12ms" />
                <TextView
                    android:id="@+id/tvJitter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="±2ms" />
            </LinearLayout>

            <!-- Download card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ DOWNLOAD"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tvDownload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_blue"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_bold"
                    tools:text="245.8" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mbps"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Upload card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ UPLOAD"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tvUpload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_purple"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_bold"
                    tools:text="89.3" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mbps"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Results card (shown after test) -->
        <LinearLayout
            android:id="@+id/cardResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚀 EXCELLENT"
                android:textColor="@color/accent_cyan"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVER"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvServerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detecting..."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        tools:text="New York, US" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISP"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvIspName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detecting..."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        tools:text="Comcast Cable" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
