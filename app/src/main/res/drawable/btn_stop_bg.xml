<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#CC2200"
                android:endColor="#AA1100"
                android:angle="135" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF4422"
                android:endColor="#CC2200"
                android:angle="135" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#FF6644" />
        </shape>
    </item>
</selector>
